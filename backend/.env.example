# ── App ───────────────────────────────────────────────────────────
APP_NAME=VOICE
APP_ENV=development
APP_PORT=8000
DEBUG=True

# ── AI Providers ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...
GOOGLE_API_KEY=AIzaSy...
SARVAM_API_KEY=...

# ── Ollama — Forge Mode (Free Models) ─────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MISTRAL_MODEL=mistral
OLLAMA_GEMMA_MODEL=gemma

# ── Database — Supabase ───────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Authentication ────────────────────────────────────────────────
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
RESET_TOKEN_EXPIRE_MINUTES=60

# ── Email — Gmail SMTP (password reset) ───────────────────────────
# Use a Google App Password (requires 2-Step Verification on the account)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@wtxindia.com
SMTP_PASSWORD=your-16-char-app-password
FROM_EMAIL=you@wtxindia.com
FROM_NAME=WTX Voice

# Base URL of the frontend — used to build the reset link in emails
FRONTEND_URL=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── CORS ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000